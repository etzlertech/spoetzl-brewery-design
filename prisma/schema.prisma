// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model for authentication
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  images        Image[]
  videos        Video[]
  maps          Map[]
  plans         Plan[]
  enhancements  Enhancement[]
  specifications Specification[]
  comments      Comment[]

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Content models
model Image {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  url         String
  category    Category
  tags        String[]
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    Comment[]

  @@index([category])
  @@index([userId])
  @@map("images")
}

model Video {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  url         String
  type        VideoType  @default(UPLOAD)
  category    Category
  tags        String[]
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  comments    Comment[]

  @@index([category])
  @@index([userId])
  @@map("videos")
}

model Map {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  url         String
  mapType     MapType
  tags        String[]
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    Comment[]

  @@index([mapType])
  @@index([userId])
  @@map("maps")
}

model Plan {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  content     String    @db.Text
  phase       Phase     @default(PLANNING)
  priority    Priority  @default(MEDIUM)
  fileUrl     String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments    Comment[]

  @@index([phase])
  @@index([priority])
  @@index([userId])
  @@map("plans")
}

model Enhancement {
  id          String             @id @default(cuid())
  title       String
  description String             @db.Text
  category    EnhancementCategory
  priority    Priority           @default(MEDIUM)
  status      Status             @default(PROPOSED)
  budget      Int?
  imageUrls   String[]
  tags        String[]
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  comments    Comment[]

  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([userId])
  @@map("enhancements")
}

model Specification {
  id          String          @id @default(cuid())
  title       String
  description String          @db.Text
  category    SpecCategory
  details     String          @db.Text
  measurements String?        @db.Text
  materials   String?         @db.Text
  imageUrls   String[]
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  comments    Comment[]

  @@index([category])
  @@index([userId])
  @@map("specifications")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  imageId         String?
  image           Image?         @relation(fields: [imageId], references: [id], onDelete: Cascade)
  videoId         String?
  video           Video?         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  mapId           String?
  map             Map?           @relation(fields: [mapId], references: [id], onDelete: Cascade)
  planId          String?
  plan            Plan?          @relation(fields: [planId], references: [id], onDelete: Cascade)
  enhancementId   String?
  enhancement     Enhancement?   @relation(fields: [enhancementId], references: [id], onDelete: Cascade)
  specificationId String?
  specification   Specification? @relation(fields: [specificationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("comments")
}

// Enums
enum Category {
  GARDENS_LANDSCAPING
  WATER_FEATURES
  ARCHITECTURE
  PATHWAYS
  THEMING_DETAILS
  LIGHTING
  SEATING_AREAS
  SEASONAL
  OTHER
}

enum VideoType {
  UPLOAD
  YOUTUBE
  VIMEO
}

enum MapType {
  OVERALL_LAYOUT
  GARDEN_SECTIONS
  PEDESTRIAN_FLOW
  WATER_FEATURES
  THEMED_DISTRICTS
  AMENITIES
}

enum Phase {
  PLANNING
  DESIGN
  IMPLEMENTATION
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  PROPOSED
  APPROVED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum EnhancementCategory {
  GARDENS_GREEN_SPACES
  WATER_FEATURES
  PATHWAYS_CIRCULATION
  LIGHTING_ATMOSPHERE
  THEMED_STRUCTURES
  FURNITURE_AMENITIES
}

enum SpecCategory {
  LANDSCAPING
  HARDSCAPE
  WATER_FEATURES
  LIGHTING
  FURNITURE
  ARCHITECTURE
}
